    <!-- Text to Speech Button -->
    <button class="tts-btn" onclick="toggleTTS()" title="Text to Speech">
        <i class="fas fa-volume-up text-xl"></i>
    </button>

    <script>
        // Initialize GSAP
        gsap.registerPlugin(ScrollTrigger);

        // Animations on Load
        window.addEventListener('load', () => {
            // Hero animations
            gsap.to('#heroTitle', { opacity: 1, y: 0, duration: 1, ease: 'power3.out', delay: 0.2 });
            gsap.to('#heroSubtitle', { opacity: 1, y: 0, duration: 1, ease: 'power3.out', delay: 0.4 });
            gsap.to('#heroCta', { opacity: 1, y: 0, duration: 1, ease: 'power3.out', delay: 0.6 });

            // Scroll animations
            gsap.utils.toArray('.glass-card').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,
                        start: 'top 80%',
                    },
                    y: 50,
                    opacity: 0,
                    duration: 0.6,
                    delay: i * 0.1,
                    ease: 'power2.out'
                });
            });

            gsap.utils.toArray('.tool-card').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,
                        start: 'top 85%',
                    },
                    scale: 0.8,
                    opacity: 0,
                    duration: 0.5,
                    delay: i * 0.1,
                    ease: 'back.out(1.7)'
                });
            });
        });

        // Navigation scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 50) {
                nav.classList.add('shadow-lg', 'shadow-blue-500/10');
            } else {
                nav.classList.remove('shadow-lg', 'shadow-blue-500/10');
            }
        });

        // Mobile menu toggle
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('translate-x-full');
        }

        // Smooth scroll
        function scrollToSection(id) {
            document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
        }

        // Login Modal
        let isLoginMode = true;
        
        function toggleLoginModal() {
            const modal = document.getElementById('loginModal');
            const content = document.getElementById('modalContent');
            
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            } else {
                content.classList.remove('scale-100', 'opacity-100');
                content.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 300);
            }
        }

        function toggleAuthMode() {
            isLoginMode = !isLoginMode;
            const nameField = document.getElementById('nameField');
            const phoneField = document.getElementById('phoneField');
            const modalTitle = document.getElementById('modalTitle');
            const submitBtnText = document.getElementById('submitBtnText');
            const toggleText = document.getElementById('toggleText');
            const toggleBtn = document.getElementById('toggleBtn');

            if (isLoginMode) {
                nameField.classList.add('hidden');
                phoneField.classList.add('hidden');
                modalTitle.textContent = 'Welcome Back';
                submitBtnText.textContent = 'Login';
                toggleText.textContent = "Don't have an account?";
                toggleBtn.textContent = 'Register';
            } else {
                nameField.classList.remove('hidden');
                phoneField.classList.remove('hidden');
                modalTitle.textContent = 'Create Account';
                submitBtnText.textContent = 'Register';
                toggleText.textContent = 'Already have an account?';
                toggleBtn.textContent = 'Login';
            }
        }

        // Auth handling
        let currentUser = null;

        function handleAuth(e) {
            e.preventDefault();
            const email = document.getElementById('emailInput').value;
            
            // Simulate authentication
            currentUser = {
                email: email,
                name: 'Student',
                deviceId: 'device_' + Math.random().toString(36).substr(2, 9)
            };
            
            localStorage.setItem('aiPoddaUser', JSON.stringify(currentUser));
            
            toggleLoginModal();
            updateUIForLoggedInUser();
            
            // Show success notification
            showNotification('Successfully logged in! Welcome to AI පොඩ්ඩා', 'success');
        }

        function logout() {
            currentUser = null;
            localStorage.removeItem('aiPoddaUser');
            updateUIForLoggedOutUser();
            showNotification('Logged out successfully', 'info');
        }

        function updateUIForLoggedInUser() {
            document.getElementById('loginBtn').classList.add('hidden');
            document.getElementById('logoutBtn').classList.remove('hidden');
            document.getElementById('lockedOverlay').classList.add('hidden');
            document.getElementById('videosGrid').classList.remove('blur-sm');
            document.getElementById('courseLock').innerHTML = '<i class="fas fa-unlock text-green-400"></i><span class="text-green-400 font-semibold">Unlocked</span>';
            document.getElementById('loadMoreBtn').style.display = 'inline-block';
        }

        function updateUIForLoggedOutUser() {
            document.getElementById('loginBtn').classList.remove('hidden');
            document.getElementById('logoutBtn').classList.add('hidden');
            document.getElementById('lockedOverlay').classList.remove('hidden');
            document.getElementById('videosGrid').classList.add('blur-sm');
            document.getElementById('courseLock').innerHTML = '<i class="fas fa-lock"></i><span class="font-semibold">Login Required</span>';
            document.getElementById('loadMoreBtn').style.display = 'none';
        }

        // Check for existing session
        window.addEventListener('load', () => {
            const savedUser = localStorage.getItem('aiPoddaUser');
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                updateUIForLoggedInUser();
            }
        });

        // Text to Speech
        let ttsEnabled = false;
        const synth = window.speechSynthesis;

        function toggleTTS() {
            ttsEnabled = !ttsEnabled;
            const btn = document.querySelector('.tts-btn');
            
            if (ttsEnabled) {
                btn.classList.add('glow-anim');
                btn.style.background = 'linear-gradient(135deg, #00d4ff, #0066ff)';
                showNotification('Text-to-Speech enabled. Click on any text to hear it.', 'info');
                enableTTSClicks();
            } else {
                btn.classList.remove('glow-anim');
                btn.style.background = 'linear-gradient(135deg, #0066ff, #00d4ff)';
                synth.cancel();
                disableTTSClicks();
            }
        }

        function enableTTSClicks() {
            document.body.addEventListener('click', handleTTSClick);
        }

        function disableTTSClicks() {
            document.body.removeEventListener('click', handleTTSClick);
        }

        function handleTTSClick(e) {
            if (!ttsEnabled) return;
            if (e.target.closest('.tts-btn')) return;
            
            const text = e.target.textContent || e.target.innerText;
            if (text && text.length > 3) {
                speakText(text);
            }
        }

        function speakText(text) {
            if (synth.speaking) {
                synth.cancel();
            }
            
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'si-LK'; // Sinhala
            utterance.rate = 0.9;
            utterance.pitch = 1;
            
            // Try to find a Sinhala voice
            const voices = synth.getVoices();
            const sinhalaVoice = voices.find(voice => voice.lang.includes('si') || voice.lang.includes('Sinhala'));
            if (sinhalaVoice) {
                utterance.voice = sinhalaVoice;
            }
            
            synth.speak(utterance);
        }

        function playIntroVoice() {
            const text = document.querySelector('.sinhala-text').textContent;
            speakText(text);
            
            // Animate voice wave
            const wave = document.getElementById('voiceWave');
            wave.style.opacity = '1';
            setTimeout(() => {
                wave.style.opacity = '0.5';
            }, 1000);
        }

        function playNewsVoice() {
            const news = document.getElementById('newsTicker').textContent;
            speakText(news);
        }

        // Notification system
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            const colors = {
                success: 'from-green-500 to-emerald-600',
                info: 'from-blue-500 to-cyan-600',
                error: 'from-red-500 to-pink-600'
            };
            
            notification.className = `fixed top-24 right-4 z-50 bg-gradient-to-r ${colors[type]} text-white px-6 py-3 rounded-xl shadow-2xl transform translate-x-full transition-transform duration-300 flex items-center gap-3`;
            notification.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span class="font-semibold">${message}</span>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.classList.remove('translate-x-full');
            }, 100);
            
            setTimeout(() => {
                notification.classList.add('translate-x-full');
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // Particle effect on click
        document.addEventListener('click', (e) => {
            if (e.target.closest('button') || e.target.closest('a')) {
                createParticles(e.clientX, e.clientY);
            }
        });

        function createParticles(x, y) {
            for (let i = 0; i < 8; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = x + 'px';
                particle.style.top = y + 'px';
                
                const angle = (Math.PI * 2 * i) / 8;
                const velocity = 50 + Math.random() * 50;
                const tx = Math.cos(angle) * velocity;
                const ty = Math.sin(angle) * velocity;
                
                particle.style.setProperty('--tx', tx + 'px');
                particle.style.setProperty('--ty', ty + 'px');
                
                document.body.appendChild(particle);
                
                gsap.to(particle, {
                    x: tx,
                    y: ty,
                    opacity: 1,
                    duration: 0.3,
                    ease: 'power2.out',
                    onComplete: () => {
                        gsap.to(particle, {
                            opacity: 0,
                            duration: 0.3,
                            onComplete: () => particle.remove()
                        });
                    }
                });
            }
        }

        // Simulate live news updates
        setInterval(() => {
            const ticker = document.getElementById('newsTicker');
            const updates = [
                '🚀 Breaking: New AI model achieves human-level reasoning',
                '🎨 Creative AI tools now support real-time collaboration',
                '💼 AI startups raise $2B in funding this week',
                '📱 Mobile AI processing reaches new efficiency milestones',
                '🎵 AI-generated music tops charts in 12 countries'
            ];
            const randomUpdate = updates[Math.floor(Math.random() * updates.length)];
            ticker.textContent = randomUpdate + ' • ' + ticker.textContent.split('•').slice(0, 6).join('•');
        }, 30000); // Update every 30 seconds

        // Device detection (single device login simulation)
        window.addEventListener('beforeunload', () => {
            if (currentUser) {
                localStorage.setItem('lastDevice', currentUser.deviceId);
            }
        });

        // Check if another device is logged in
        window.addEventListener('storage', (e) => {
            if (e.key === 'lastDevice' && currentUser && e.newValue !== currentUser.deviceId) {
                alert('Your account has been accessed from another device. You have been logged out for security.');
                logout();
            }
        });
    </script>
</body>
</html>