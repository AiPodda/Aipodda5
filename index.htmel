                </a>

                <a href="#" target="_blank" class="social-icon flex flex-col items-center gap-3 group" style="color: #FF0000;">
                    <div class="w-20 h-20 rounded-2xl bg-red-600/20 border border-red-500/50 flex items-center justify-center text-4xl text-red-500 group-hover:bg-red-600/30 transition-all">
                        <i class="fab fa-youtube"></i>
                    </div>
                    <span class="font-semibold text-red-400">YouTube</span>
                </a>

                <a href="https://whatsapp.com/channel/0029Vb7R7sP6WaKgGMs4oy1X" target="_blank" class="social-icon flex flex-col items-center gap-3 group" style="color: #25D366;">
                    <div class="w-20 h-20 rounded-2xl bg-green-500/20 border border-green-500/50 flex items-center justify-center text-4xl text-green-500 group-hover:bg-green-500/30 transition-all">
                        <i class="fab fa-whatsapp"></i>
                    </div>
                    <span class="font-semibold text-green-400">WhatsApp Channel</span>
                </a>
            </div>
        </div>
    </section>

    <!-- AI News Ticker -->
    <section class="py-8 bg-blue-900/30 border-y border-blue-500/30">
        <div class="flex items-center gap-4 px-4 mb-2">
            <span class="bg-red-500 text-white px-3 py-1 rounded text-sm font-bold animate-pulse">LIVE</span>
            <span class="font-semibold text-blue-300">AI Daily Updates</span>
            <button onclick="playNewsVoice()" class="text-cyan-400 hover:text-cyan-300 ml-auto flex items-center gap-2">
                <i class="fas fa-volume-up"></i> Listen
            </button>
        </div>
        <div class="news-ticker glass py-3">
            <div class="news-ticker-content text-lg" id="newsTicker">
                🚀 OpenAI launches GPT-5 with video understanding • 🎨 Midjourney V7 released with photorealistic mode • 🤖 Google DeepMind achieves breakthrough in robotic learning • 💼 AI generates $4.4 trillion in global economic value • 🎵 New AI music tools rival professional producers • 📱 Samsung integrates AI into all 2026 devices • 🚗 Tesla Full Self-Driving reaches 99.9% safety score
            </div>
        </div>
    </section>

    <!-- AI Tools Section -->
    <section class="py-20 px-4">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
                Powerful AI Tools
            </h2>
            <p class="text-center text-gray-400 mb-12 max-w-2xl mx-auto">Access the world's leading AI platforms to create stunning content</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="tool-card rounded-2xl p-6 flex flex-col items-center text-center group cursor-pointer" onclick="window.open('https://gemini.google.com', '_blank')">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-brain"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Gemini</h3>
                    <p class="text-gray-400 text-sm mb-4">Google's most capable AI model for reasoning and creativity</p>
                    <span class="text-blue-400 text-sm font-semibold flex items-center gap-2">
                        Access Tool <i class="fas fa-external-link-alt"></i>
                    </span>
                </div>

                <div class="tool-card rounded-2xl p-6 flex flex-col items-center text-center group cursor-pointer" onclick="window.open('https://flowgpt.com', '_blank')">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-pink-500 to-orange-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">FlowGPT</h3>
                    <p class="text-gray-400 text-sm mb-4">Community-driven AI prompts and workflows platform</p>
                    <span class="text-blue-400 text-sm font-semibold flex items-center gap-2">
                        Access Tool <i class="fas fa-external-link-alt"></i>
                    </span>
                </div>

                <div class="tool-card rounded-2xl p-6 flex flex-col items-center text-center group cursor-pointer" onclick="window.open('https://chat.openai.com', '_blank')">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-green-500 to-teal-600 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">ChatGPT</h3>
                    <p class="text-gray-400 text-sm mb-4">OpenAI's conversational AI for text generation and coding</p>
                    <span class="text-blue-400 text-sm font-semibold flex items-center gap-2">
                        Access Tool <i class="fas fa-external-link-alt"></i>
                    </span>
                </div>

                <div class="tool-card rounded-2xl p-6 flex flex-col items-center text-center group cursor-pointer" onclick="window.open('https://hailuoai.video', '_blank')">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-video"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">HailuoAI</h3>
                    <p class="text-gray-400 text-sm mb-4">AI video generation from text prompts</p>
                    <span class="text-blue-400 text-sm font-semibold flex items-center gap-2">
                        Access Tool <i class="fas fa-external-link-alt"></i>
                    </span>
                </div>

                <div class="tool-card rounded-2xl p-6 flex flex-col items-center text-center group cursor-pointer" onclick="window.open('https://suno.com', '_blank')">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-yellow-500 to-red-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
