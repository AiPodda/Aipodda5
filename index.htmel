                <div class="mt-6 text-center">
                    <p class="text-gray-400 text-sm">
                        <span id="toggleText">Don't have an account?</span>
                        <button onclick="toggleAuthMode()" class="text-blue-400 hover:text-blue-300 font-semibold ml-1" id="toggleBtn">Register</button>
                    </p>
                </div>

                <div class="mt-6 pt-6 border-t border-white/10">
                    <p class="text-xs text-gray-500 text-center mb-3">Or continue with</p>
                    <div class="flex gap-3">
                        <button class="flex-1 bg-white/5 border border-white/20 rounded-xl py-2 hover:bg-white/10 transition-all flex items-center justify-center gap-2">
                            <i class="fab fa-google text-red-400"></i> Google
                        </button>
                        <button class="flex-1 bg-white/5 border border-white/20 rounded-xl py-2 hover:bg-white/10 transition-all flex items-center justify-center gap-2">
                            <i class="fab fa-facebook text-blue-400"></i> Facebook
                        </button>
